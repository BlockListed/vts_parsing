		Briefing

		{

			BRIEFING_NOTE

			{

				text = You''ve been transferred to the airbase near Gloom Lake.  ///n///nThis lake lies on another border between our nation and the enemy''s, and is where they conduct tests on naval vessels and aircraft.

				imagePath = opDesert\ss4.png

				audioClipPath = 

			}

			BRIEFING_NOTE

			{

				text = There have been an unusually high number of enemy drones harassing us recently.  They fly dangerously close to our base and force us to take defensive measures.  ///n///nWe believe that they''re attempting to distract us while they test new military technologies.

				imagePath = opDesert\ss4.png

				audioClipPath = 

			}

			BRIEFING_NOTE

			{

				text = In order to put a damper on their research efforts, we''re sending out a group of F/A-26Bs configured to sink their test ships.///n///nAlthough this is a testing area, the enemy ships are fully functional and armed.

				imagePath = TheIsland\Mission6\ti-m6_asm.png

				audioClipPath = 

			}

			BRIEFING_NOTE

			{

				text = You and your wingmen are tasked to destroy enemy air defenses and patrol aircraft, to allow the strikers to perform the anti-shipping attack.///n///nThe strikers will be in the air waiting for you.  Join them and escort them along their attack path.

				imagePath = TheIsland\Mission6\ti-m6_asm.png

				audioClipPath = 

			}

			BRIEFING_NOTE

			{

				text = When you reach the end of the attack path, the strikers will begin anti-shipping. Target radars to prevent them from defending against the attack.///n///nSimultaneously, allied combat air patrol will be vectored to the area to help keep enemy aircraft away.

				imagePath = TheIsland\Mission6\ti-m6_asm.png

				audioClipPath = 

			}

			BRIEFING_NOTE

			{

				text = SUMMARY:///nObjective: Support strikers while they attack enemy ships.///n- Suppress enemy air defenses///n- Defend strikers from enemy air patrols///n///nPrimary Targets:///n- Radars///n- Aggressive Aircraft///n///nThreats:///n- Ships///n- Aircraft///n- SAMs///n- AAA

				imagePath = opDesert\ss4.png

				audioClipPath = 

			}

		}

